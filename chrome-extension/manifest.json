{
  "manifest_version": 3,
  "name": "ChromaCheck",
  "description": "WCAG 2.1 & APCA contrast checker for any webpage. Extract colors and instantly analyze accessibility compliance.",
  "version": "1.0.0",
  "permissions": ["activeTab", "scripting", "storage", "sidePanel"],
  "action": {
    "default_title": "Open ChromaCheck",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup/popup.html"
  },
  "devtools_page": "devtools/devtools.html",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "chromacheck@ryanjohnson.com",
      "strict_min_version": "109.0"
    }
  }
}
